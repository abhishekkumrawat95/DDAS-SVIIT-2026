# DDAS Environment Variables Template
# Copy this file to .env and fill in your values.
# The application reads these at startup.

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file.
# Defaults to: <project_root>/data/ddas.db
DDAS_DB_PATH=./data/ddas.db

# ── File Monitoring ───────────────────────────────────────────────────────────
# Comma-separated list of folder paths to monitor for new downloads.
DDAS_MONITOR_FOLDERS=C:\Users\YourName\Downloads

# How often (seconds) to check alerts and re-scan folders.
DDAS_SCAN_INTERVAL=5

# ── Duplicate Detection ───────────────────────────────────────────────────────
# TF-IDF cosine similarity threshold for text documents [0.0 – 1.0].
TEXT_SIMILARITY_THRESHOLD=0.85

# Maximum Hamming distance between two image pHashes to consider them duplicates.
IMAGE_HASH_THRESHOLD=10

# ── Email Notifications ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
ADMIN_EMAIL=admin@example.com

# ── REST API ──────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=5000
API_DEBUG=false

# ── Chatbot ───────────────────────────────────────────────────────────────────
# Set to 'true' to enable DuckDuckGo online search from the chatbot.
ONLINE_SEARCH_ENABLED=false
ONLINE_SEARCH_MAX_RESULTS=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/ddas.log
